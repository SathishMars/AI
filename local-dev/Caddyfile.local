# Caddy configuration for local embedded development
# Both Rails (port 3000) and Next.js (port 3001) running locally
# Access at: http://groupize.local

{
    # Global options
    admin off
    auto_https off
}

http://groupize.local {
    # Next.js Workflows app at /aime/*
    handle /aime/* {
        reverse_proxy localhost:3001 {
            # Forward original headers
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            
            # Support WebSocket for HMR
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
            
            # Long timeouts for AI operations
            transport http {
                dial_timeout 300s
                response_header_timeout 300s
            }
        }
    }
    
    # Next.js internal routes (_next, __, etc.)
    handle /_next/* {
        reverse_proxy localhost:3001
    }
    
    handle /__* {
        reverse_proxy localhost:3001
    }
    
    # Everything else goes to Rails
    handle {
        reverse_proxy localhost:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    
    # Logging
    log {
        output file /opt/homebrew/var/log/caddy/groupize.local.log
        format console
    }
}

