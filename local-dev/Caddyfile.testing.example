# Caddy configuration for split-routing with testing environment
# Local Next.js dev server (port 3000) for /aime/*
# Real testing.app.groupize.com for everything else
#
# PREREQUISITES:
# 1. Add to /etc/hosts: 127.0.0.1 testing.app.groupize.com
# 2. Generate mkcert certificates in ~/.local-dev-certs/
# 3. Replace YOUR_USERNAME with your actual macOS username
#
# SECURITY: Only use for non-production environments!

{
    # Global options
    admin off
    auto_https off
    
    # Bind only to localhost for security
    local_certs
}

https://testing.app.groupize.com {
    # Use mkcert certificates
    # IMPORTANT: Replace YOUR_USERNAME with your actual username (e.g., mdarwin)
    tls /Users/YOUR_USERNAME/.local-dev-certs/testing.app.groupize.com.pem /Users/YOUR_USERNAME/.local-dev-certs/testing.app.groupize.com-key.pem
    
    # Bind only to localhost (security)
    bind 127.0.0.1
    
    # Route /aime/* to LOCAL Next.js dev server
    handle /aime/* {
        reverse_proxy localhost:3000 {
            # Preserve headers and cookies
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto https
            
            # Support WebSocket for HMR
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
            
            # Long timeouts for AI operations
            transport http {
                dial_timeout 300s
                response_header_timeout 300s
            }
        }
    }
    
    # Next.js internal routes to local dev server
    handle /_next/* {
        reverse_proxy localhost:3000 {
            header_up Host {host}
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }
    
    handle /__* {
        reverse_proxy localhost:3000 {
            header_up Host {host}
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }
    
    # Everything else goes to REAL testing environment
    # NOTE: Use real IP to avoid infinite loop with /etc/hosts override
    # To find IP: nslookup testing.app.groupize.com (when /etc/hosts is commented out)
    handle {
        reverse_proxy https://104.18.10.206 {
            # Preserve original host for AWS routing
            header_up Host testing.app.groupize.com
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto https
            
            # Don't verify cert (it's the real testing server)
            transport http {
                tls_insecure_skip_verify
                tls_server_name testing.app.groupize.com
            }
        }
    }
    
    # Logging
    log {
        output file /opt/homebrew/var/log/caddy/testing-split.log
        format console
    }
}

