# Groupize Workflows - Environment Configuration Template
# Copy this file to .env.local and fill in your API keys and configuration
# This file is tracked in git as a template for developers and CI/CD systems

# OpenAI Configuration (Required for GPT models)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Configuration (Required for Claude models)  
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# LM Studio Configuration (Optional for local model inference)
# Enable LM Studio provider for local model usage
LMSTUDIO_ENABLED=false
# LM Studio server endpoint (default: http://localhost:1234/v1)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Model name to use (configure in LM Studio or specify here)
LMSTUDIO_MODEL=llama-3.1-8b-instruct
# Optional API key (LM Studio doesn't require real authentication)
LMSTUDIO_API_KEY=lm-studio

# LLM Provider Configuration
# Set the default LLM provider (openai, anthropic, lmstudio)
# If not set, will use first available provider in priority order: openai -> anthropic -> lmstudio
# DEFAULT_LLM_PROVIDER=openai
# Enable detailed LLM logging (provider, model, timing info)
# LLM_DETAILED_LOGGING=true

# OpenAI Model Override Configuration (Optional - uses defaults if not set)
# Override specific models for different use cases
# OPENAI_MODEL_WORKFLOW=gpt-4-turbo-preview
# OPENAI_MODEL_CONVERSATION=gpt-4-turbo-preview
# OPENAI_MODEL_MERMAID=gpt-4

# Anthropic Model Override Configuration (Optional - uses defaults if not set)
# Override specific models for different use cases
# ANTHROPIC_MODEL_WORKFLOW=claude-3-5-sonnet-20240620
# ANTHROPIC_MODEL_CONVERSATION=claude-3-5-sonnet-20240620
# ANTHROPIC_MODEL_MERMAID=claude-3-haiku-20240307

# Optional: Rate limiting configuration
OPENAI_RATE_LIMIT_RPM=60
OPENAI_RATE_LIMIT_TPM=150000
ANTHROPIC_RATE_LIMIT_RPM=50
ANTHROPIC_RATE_LIMIT_TPM=100000

# Development Settings
NODE_ENV=development

# Database Configuration
# Set DATABASE_ENVIRONMENT to 'local' for MongoDB or 'documentdb' for AWS DocumentDB
DATABASE_ENVIRONMENT=local

# MongoDB Connection URI (for local development)
# Used by both MongoDB connection utility and LangChain for conversation memory
MONGODB_URI=mongodb://groupize_app:your-password-here@localhost:27017/groupize-workflows

# AWS DocumentDB Connection URI (for production)
# Only required when DATABASE_ENVIRONMENT=documentdb
# DOCUMENTDB_URI=mongodb://username:password@your-documentdb-cluster.cluster-xyz.us-east-1.docdb.amazonaws.com:27017/groupize-workflows?ssl=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false


# Application Settings
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ENABLE_MOCK_DATA=true