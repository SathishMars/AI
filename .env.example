# Groupize Workflows - Environment Configuration Template
# Copy this file to .env.local and fill in your API keys and configuration
# This file is tracked in git as a template for developers and CI/CD systems

# OpenAI Configuration (Required for GPT models)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Configuration (Required for Claude models)  
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Optional: Rate limiting configuration
OPENAI_RATE_LIMIT_RPM=60
OPENAI_RATE_LIMIT_TPM=150000
ANTHROPIC_RATE_LIMIT_RPM=50
ANTHROPIC_RATE_LIMIT_TPM=100000

# Development Settings
NODE_ENV=development

# Database Configuration
# Set DATABASE_ENVIRONMENT to 'local' for MongoDB or 'documentdb' for AWS DocumentDB
DATABASE_ENVIRONMENT=local

# MongoDB Connection Settings (for local development)
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=groupize_app
MONGODB_PASSWORD=your-password-here
MONGODB_DATABASE=groupize-workflows

# AWS DocumentDB Connection Settings (for production)
# Only required when DATABASE_ENVIRONMENT=documentdb
DOCUMENTDB_HOST=your-documentdb-cluster.cluster-xyz.us-east-1.docdb.amazonaws.com
DOCUMENTDB_PORT=27017
DOCUMENTDB_USER=your-documentdb-username
DOCUMENTDB_PASSWORD=your-documentdb-password

# Alternative: Full MongoDB Connection String (for local development)
MONGODB_URI=mongodb://groupize_app:gr0up!zeapP@localhost:27017/groupize-workflows

# Legacy MongoDB Settings (for backward compatibility)
MONGODB_DB_NAME=groupize-workflows
MONGODB_DB_AUTH_SOURCE=admin
MONGODB_DB_SSL=false


# Application Settings
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ENABLE_MOCK_DATA=true