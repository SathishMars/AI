# NPM Configuration for Groupize Workflows
# This file ensures consistent package installation across local and CI/CD environments

# Use legacy peer dependency resolution to handle conflicting peer dependencies
# Required for: zod v4 (our project) vs zod v3 (stagehand/langchain dependencies)
legacy-peer-deps=true

# Automatically rebuild native modules after install
# Required for: lightningcss native bindings
rebuild-bundle=true
